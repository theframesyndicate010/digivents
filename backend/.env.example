# Server
HOST=0.0.0.0
PORT=1337
NODE_ENV=production
CLIENT_URL=https://yourdomain.com

# Secrets - GENERATE NEW VALUES FOR PRODUCTION
APP_KEYS="generateNewValue1,generateNewValue2"
API_TOKEN_SALT=generateNewValue
ADMIN_JWT_SECRET=generateNewValue
TRANSFER_TOKEN_SALT=generateNewValue
ENCRYPTION_KEY=generateNewValue
JWT_SECRET=generateNewValue

# Database - Strapi Cloud Managed Postgres
DATABASE_CLIENT=postgres
DATABASE_URL=postgresql://username:password@db.project-id.supabase.co:5432/postgres
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_SCHEMA=public
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10

# File Upload Provider - Supabase or your chosen service
SUPABASE_URL=https://project-id.supabase.co
SUPABASE_API_URL=https://project-id.supabase.co
SUPABASE_API_KEY=your-project-anon-key
SUPABASE_BUCKET=uploads
SUPABASE_DIRECTORY=uploads

# Image Optimization Service
IMAGEKIT_PUBLIC_KEY=your-public-key
IMAGEKIT_PRIVATE_KEY=your-private-key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-account/
