# Server
HOST=0.0.0.0
PORT=1337
NODE_ENV=production
PUBLIC_URL=https://api.digivents.com.np

# Secrets - GENERATE NEW VALUES FOR PRODUCTION
# Use: openssl rand -hex 16 to generate new values
APP_KEYS="[\"value1\",\"value2\",\"value3\"]"
API_TOKEN_SALT=generateNewValue
ADMIN_JWT_SECRET=generateNewValue
TRANSFER_TOKEN_SALT=generateNewValue
ENCRYPTION_KEY=generateNewValue
JWT_SECRET=generateNewValue

# This is the PREFERRED way to connect on Railway
DATABASE_URL=postgresql://username:password@host:5432/database
DATABASE_SCHEMA=public

# Optional: Individual database settings (used only if DATABASE_URL is not set)
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=digivents
DATABASE_USERNAME=username
DATABASE_PASSWORD=password
DATABASE_SSL=true
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# File Upload Provider - Supabase or your chosen service
SUPABASE_URL=https://project-id.supabase.co
SUPABASE_API_URL=https://project-id.supabase.co
SUPABASE_API_KEY=your-project-anon-key
SUPABASE_BUCKET=uploads
SUPABASE_DIRECTORY=uploads

# Image Optimization Service
IMAGEKIT_PUBLIC_KEY=your-public-key
IMAGEKIT_PRIVATE_KEY=your-private-key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-account/
