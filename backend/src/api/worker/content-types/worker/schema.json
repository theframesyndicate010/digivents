{
  "kind": "collectionType",
  "collectionName": "workers",
  "info": {
    "singularName": "worker",
    "pluralName": "workers",
    "displayName": "Worker",
    "description": "Team members"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 150
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "role": {
      "type": "string",
      "required": true,
      "maxLength": 100
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "description": {
      "type": "richtext"
    },
    "projects": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::project.project",
      "inversedBy": "workers"
    }
  }
}
