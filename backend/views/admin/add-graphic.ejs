<%- include('layout', { title: 'Add Graphic', currentPage: 'graphics', pageScript: '/js/add-graphic.js', body: `
<div class="bg-white rounded-lg shadow">
    <div class="p-4 md:p-6 border-b border-gray-200 flex items-center justify-between gap-2">
        <div class="flex items-center gap-2 md:gap-3 min-w-0">
            <a href="/admin/graphics" class="text-gray-600 hover:text-gray-800 transition-colors flex-shrink-0">
                <i class="fas fa-arrow-left text-lg"></i>
            </a>
            <h3 class="text-base md:text-lg font-semibold text-gray-800 truncate">Add New Graphic</h3>
        </div>
    </div>
    <div class="p-4 md:p-6">
        <div id="formAlert" class="hidden mb-4 rounded-lg px-4 py-3 text-sm"></div>
        <form id="addGraphicForm" class="space-y-4 md:space-y-6 max-w-2xl">
            <div>
                <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Title / Name *</label>
                <input type="text" id="name" name="name" required class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base">
            </div>

            <div>
                <label for="description" class="block text-sm font-medium text-gray-700 mb-2">Description</label>
                <textarea id="description" name="description" rows="3" class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base"></textarea>
            </div>

            <div>
                <label for="photo" class="block text-sm font-medium text-gray-700 mb-2">Graphic Image *</label>
                <div class="mt-1 flex justify-center px-3 md:px-6 pt-4 md:pt-5 pb-5 md:pb-6 border-2 border-gray-300 border-dashed rounded-lg hover:border-gray-400 transition-colors">
                    <div class="space-y-2 text-center">
                        <i class="fas fa-image text-gray-400 text-3xl md:text-4xl mb-2 block"></i>
                        <div class="flex flex-col text-sm text-gray-600 justify-center items-center gap-1">
                            <label for="photo" class="relative cursor-pointer bg-white rounded-md font-medium text-blue-600 hover:text-blue-500 focus-within:outline-none focus-within:ring-2 focus-within:ring-offset-2 focus-within:ring-blue-500">
                                <span>Upload a file</span>
                                <input id="photo" name="photo" type="file" class="sr-only" accept="image/*" required>
                            </label>
                            <p>or drag and drop</p>
                        </div>
                        <p class="text-xs text-gray-500">PNG, JPG, WEBP, GIF up to 5MB</p>
                    </div>
                </div>
            </div>

            <div class="flex flex-col-reverse sm:flex-row justify-end gap-3 pt-4 md:pt-6 border-t">
                <a href="/admin/graphics" class="w-full sm:w-auto text-center px-4 md:px-6 py-2 md:py-2.5 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors font-medium min-h-10 flex items-center justify-center">Cancel</a>
                <button type="submit" class="w-full sm:w-auto px-4 md:px-6 py-2 md:py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium min-h-10 flex items-center justify-center">Save Graphic</button>
            </div>
        </form>
    </div>
</div>
`}) %>
