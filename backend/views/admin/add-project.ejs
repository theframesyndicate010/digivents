<%- include('layout', { title: 'Add Project' , currentPage: 'projects' , pageScript: '/js/add-project.js', body: `
<div class="bg-white rounded-lg shadow">
    <div class="p-4 md:p-6 border-b border-gray-200 flex items-center justify-between gap-2">
        <div class="flex items-center gap-2 md:gap-3 min-w-0">
            <a href="/admin/projects" class="text-gray-600 hover:text-gray-800 transition-colors flex-shrink-0">
                <i class="fas fa-arrow-left text-lg"></i>
            </a>
            <h3 class="text-base md:text-lg font-semibold text-gray-800 truncate">Add New Project</h3>
        </div>
    </div>

    <div class="p-4 md:p-6">
        <div id="formAlert" class="hidden mb-4 rounded-lg px-4 py-3 text-sm"></div>
        <form id="addProjectForm" class="space-y-4 md:space-y-6 max-w-2xl">
            <div class="pt-2 md:pt-4 border-t">
                <h4 class="text-base md:text-md font-medium text-gray-700 mb-4">Social Media Links</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2"><i class="fab fa-instagram mr-2 text-pink-600"></i>Instagram Link</label>
                        <input type="url" name="instagramLink" placeholder="https://instagram.com/..." class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2"><i class="fab fa-facebook mr-2 text-blue-600"></i>Facebook Link</label>
                        <input type="url" name="facebookLink" placeholder="https://facebook.com/..." class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2"><i class="fab fa-tiktok mr-2"></i>TikTok Link</label>
                        <input type="url" name="tiktokLink" placeholder="https://tiktok.com/..." class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2"><i class="fab fa-youtube mr-2 text-red-600"></i>YouTube Link</label>
                        <input type="url" name="youtubeLink" placeholder="https://youtube.com/..." class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base">
                    </div>
                </div>
            </div>

            <div class="flex flex-col-reverse sm:flex-row justify-end gap-3 pt-4 md:pt-6 border-t">
                <a href="/admin/projects" class="w-full sm:w-auto text-center px-4 md:px-6 py-2 md:py-2.5 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors font-medium min-h-10 flex items-center justify-center">Cancel</a>
                <button type="submit" class="w-full sm:w-auto px-4 md:px-6 py-2 md:py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium min-h-10 flex items-center justify-center">Create Project</button>
            </div>
        </form>
    </div>
</div>
`}) %>