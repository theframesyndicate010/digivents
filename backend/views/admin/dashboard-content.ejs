<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-3 rounded-full bg-blue-100 text-blue-600">
                <i class="fas fa-project-diagram text-xl"></i>
            </div>
            <div class="ml-4">
                <h3 class="text-lg font-semibold text-gray-700">Projects</h3>
                <p class="text-2xl font-bold text-gray-900"><%= stats.projects %></p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-3 rounded-full bg-green-100 text-green-600">
                <i class="fas fa-handshake text-xl"></i>
            </div>
            <div class="ml-4">
                <h3 class="text-lg font-semibold text-gray-700">Clients</h3>
                <p class="text-2xl font-bold text-gray-900"><%= stats.clients %></p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-3 rounded-full bg-yellow-100 text-yellow-600">
                <i class="fas fa-comments text-xl"></i>
            </div>
            <div class="ml-4">
                <h3 class="text-lg font-semibold text-gray-700">Feedback</h3>
                <p class="text-2xl font-bold text-gray-900"><%= stats.feedback %></p>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex items-center">
            <div class="p-3 rounded-full bg-purple-100 text-purple-600">
                <i class="fas fa-envelope text-xl"></i>
            </div>
            <div class="ml-4">
                <h3 class="text-lg font-semibold text-gray-700">Messages</h3>
                <p class="text-2xl font-bold text-gray-900"><%= stats.contacts %></p>
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-lg shadow">
        <div class="p-6 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-800">Recent Projects</h3>
        </div>
        <div class="p-6">
            <% if (recentProjects && recentProjects.length > 0) { %>
                <div class="space-y-4">
                    <% recentProjects.forEach(project => { %>
                        <div class="flex items-center justify-between">
                            <div>
                                <p class="font-medium text-gray-900"><%= project.title %></p>
                                <p class="text-sm text-gray-500">Updated <%= project.relativeTime %></p>
                            </div>
                            <span class="px-2 py-1 text-xs font-medium <%= project.statusColor %> rounded-full">
                                <%= project.statusDisplay %>
                            </span>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <p class="text-gray-500 text-center py-8">No projects yet. Create your first project to get started.</p>
            <% } %>
        </div>
    </div>

    <div class="bg-white rounded-lg shadow">
        <div class="p-6 border-b border-gray-200">
            <h3 class="text-lg font-semibold text-gray-800">Recent Messages</h3>
        </div>
        <div class="p-6">
            <% if (recentMessages && recentMessages.length > 0) { %>
                <div class="space-y-4">
                    <% recentMessages.forEach(message => { %>
                        <div class="flex items-start space-x-3">
                            <div class="w-8 h-8 bg-gray-300 rounded-full flex items-center justify-center flex-shrink-0">
                                <i class="fas fa-user text-gray-600 text-sm"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <p class="font-medium text-gray-900"><%= message.name %></p>
                                <p class="text-sm text-gray-600 truncate"><%= message.subject || message.message %></p>
                                <p class="text-xs text-gray-500 mt-1"><%= message.relativeTime %></p>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <p class="text-gray-500 text-center py-8">No messages yet. Contact messages will appear here.</p>
            <% } %>
        </div>
    </div>
</div>
