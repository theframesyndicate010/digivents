<%- include('layout', { title: 'Edit Client', currentPage: 'clients', body: `
<div class="bg-white rounded-lg shadow">
    <div class="p-4 md:p-6 border-b border-gray-200">
        <h3 class="text-lg font-semibold text-gray-800">Edit Client</h3>
    </div>

    <div class="p-4 md:p-6">
        <div id="formAlert" class="hidden mb-4 rounded-lg px-4 py-3 text-sm"></div>
        <form id="editClientForm" class="space-y-6">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Client Name *</label>
                <input type="text" name="name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Website</label>
                <input type="url" name="website" placeholder="https://example.com" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
            </div>

            <h4 class="text-md font-medium text-gray-700 pt-2 border-t">Social Media Links</h4>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Instagram</label>
                    <input type="url" name="instagramLink" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Facebook</label>
                    <input type="url" name="facebookLink" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">TikTok</label>
                    <input type="url" name="tiktokLink" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
                </div>
            </div>

            <div class="flex justify-end gap-4 pt-4 border-t">
                <a href="/admin/clients" class="px-6 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors">Cancel</a>
                <button type="submit" class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script src="/js/admin/edit-client.js"></script>
`}) %>
