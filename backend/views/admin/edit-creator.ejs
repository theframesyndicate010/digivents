<%- include('layout', { title: 'Edit Creator', currentPage: 'creators', pageScript: '/js/edit-creator.js', body: `
<div class="bg-white rounded-lg shadow">
    <div class="p-4 md:p-6 border-b border-gray-200 flex items-center justify-between gap-2">
        <div class="flex items-center gap-2 md:gap-3 min-w-0">
            <a href="/admin/creators" class="text-gray-600 hover:text-gray-800 transition-colors flex-shrink-0">
                <i class="fas fa-arrow-left text-lg"></i>
            </a>
            <h3 class="text-base md:text-lg font-semibold text-gray-800 truncate">Edit Creator</h3>
        </div>
    </div>

    <div class="p-4 md:p-6">
        <div id="formAlert" class="hidden mb-4 rounded-lg px-4 py-3 text-sm"></div>
        <form id="editCreatorForm" class="space-y-4 md:space-y-6 max-w-2xl">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Creator Name *</label>
                <input type="text" name="name" required class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Role</label>
                <input type="text" name="role" class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Description</label>
                <textarea name="description" rows="3" class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base"></textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Photo</label>
                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                    <span id="photoPreview" class="inline-block h-16 w-16 rounded-full overflow-hidden bg-gray-100 flex-shrink-0">
                        <svg id="photoPlaceholder" class="h-full w-full text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M24 20.993V24H0v-2.996A14.977 14.977 0 0112.004 15c4.904 0 9.26 2.354 11.996 5.993zM16.002 8.999a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                        <img id="photoImage" class="hidden h-full w-full object-cover" alt="Preview">
                    </span>
                    <div class="flex-1 w-full">
                        <input type="file" id="photoInput" name="photo" accept="image/*" class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg text-sm text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent cursor-pointer file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:bg-blue-50 file:text-blue-600 file:cursor-pointer">
                        <p class="mt-1 text-xs text-gray-500">Leave empty to keep current photo</p>
                    </div>
                </div>
            </div>

            <div class="flex flex-col-reverse sm:flex-row justify-end gap-3 pt-4 md:pt-6 border-t">
                <a href="/admin/creators" class="w-full sm:w-auto text-center px-4 md:px-6 py-2 md:py-2.5 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors font-medium min-h-10 flex items-center justify-center">Cancel</a>
                <button type="submit" class="w-full sm:w-auto px-4 md:px-6 py-2 md:py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium min-h-10 flex items-center justify-center">Save Changes</button>
            </div>
        </form>
    </div>
</div>
`}) %>
