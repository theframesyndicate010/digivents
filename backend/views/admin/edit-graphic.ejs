<%- include('layout', { title: 'Edit Graphic', currentPage: 'graphics', pageScript: '/js/edit-graphic.js', body: `
<div class="bg-white rounded-lg shadow">
    <div class="p-4 md:p-6 border-b border-gray-200 flex items-center justify-between gap-2">
        <div class="flex items-center gap-2 md:gap-3 min-w-0">
            <a href="/admin/graphics" class="text-gray-600 hover:text-gray-800 transition-colors flex-shrink-0">
                <i class="fas fa-arrow-left text-lg"></i>
            </a>
            <h3 class="text-base md:text-lg font-semibold text-gray-800 truncate">Edit Graphic</h3>
        </div>
    </div>

    <div class="p-4 md:p-6">
        <div id="formAlert" class="hidden mb-4 rounded-lg px-4 py-3 text-sm"></div>
        <form id="editGraphicForm" class="space-y-4 md:space-y-6 max-w-2xl">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Graphic Name *</label>
                <input type="text" name="name" required class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Description</label>
                <textarea name="description" rows="3" class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base"></textarea>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Replace Image</label>
                <input type="file" name="photo" accept="image/*" class="w-full px-3 md:px-4 py-2 md:py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-base file:mr-2 file:py-1 file:px-2 file:rounded file:border-0 file:bg-blue-50 file:text-blue-600 file:cursor-pointer">
            </div>

            <div class="flex flex-col-reverse sm:flex-row justify-end gap-3 pt-4 md:pt-6 border-t">
                <a href="/admin/graphics" class="w-full sm:w-auto text-center px-4 md:px-6 py-2 md:py-2.5 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50 transition-colors font-medium min-h-10 flex items-center justify-center">Cancel</a>
                <button type="submit" class="w-full sm:w-auto px-4 md:px-6 py-2 md:py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-medium min-h-10 flex items-center justify-center">Save Changes</button>
            </div>
        </form>
    </div>
</div>
`}) %>
