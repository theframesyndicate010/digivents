<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        @media (max-width: 768px) {
            .sidebar-mobile {
                transform: translateX(-100%);
                transition: transform 0.3s ease-in-out;
            }
            .sidebar-mobile.open {
                transform: translateX(0);
            }
        }
    </style>
</head>
<body class="bg-gray-100">
    <div class="flex h-screen overflow-hidden">
        <!-- Mobile Menu Overlay -->
        <div id="mobileMenuOverlay" class="fixed inset-0 bg-black bg-opacity-50 z-20 hidden md:hidden" onclick="toggleMobileMenu()"></div>
        
        <!-- Sidebar -->
        <div id="sidebar" class="sidebar-mobile fixed md:static inset-y-0 left-0 z-30 w-64 bg-gray-800 text-white overflow-y-auto md:translate-x-0 transition-transform duration-300 ease-in-out">
            <div class="p-4 flex items-center justify-between border-b border-gray-700">
                <h1 class="text-xl font-bold">Admin Panel</h1>
                <button onclick="toggleMobileMenu()" class="md:hidden text-white hover:text-gray-300">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <nav class="mt-4">
                <a href="/admin" class="block px-4 py-3 hover:bg-gray-700 transition-colors <%= currentPage === 'dashboard' ? 'bg-gray-700 border-l-4 border-blue-500' : '' %>">
                    <i class="fas fa-tachometer-alt w-6"></i> Dashboard
                </a>
                
                <div class="px-4 py-2 text-xs uppercase text-gray-400 font-semibold mt-4">Content</div>
                
                <a href="/admin/creators" class="block px-4 py-3 hover:bg-gray-700 transition-colors <%= currentPage === 'creators' ? 'bg-gray-700 border-l-4 border-blue-500' : '' %>">
                    <i class="fas fa-user-pen w-6"></i> Creators
                </a>
                
                <a href="/admin/clients" class="block px-4 py-3 hover:bg-gray-700 transition-colors <%= currentPage === 'clients' ? 'bg-gray-700 border-l-4 border-blue-500' : '' %>">
                    <i class="fas fa-briefcase w-6"></i> Clients
                </a>
                
                <a href="/admin/projects" class="block px-4 py-3 hover:bg-gray-700 transition-colors <%= currentPage === 'projects' ? 'bg-gray-700 border-l-4 border-blue-500' : '' %>">
                    <i class="fas fa-project-diagram w-6"></i> Projects
                </a>
                
                <a href="/admin/graphics" class="block px-4 py-3 hover:bg-gray-700 transition-colors <%= currentPage === 'graphics' ? 'bg-gray-700 border-l-4 border-blue-500' : '' %>">
                    <i class="fas fa-images w-6"></i> Graphics
                </a>

                <div class="px-4 py-2 text-xs uppercase text-gray-400 font-semibold mt-4">System</div>

                <a href="/admin/messages" class="block px-4 py-3 hover:bg-gray-700 transition-colors <%= currentPage === 'contacts' ? 'bg-gray-700 border-l-4 border-blue-500' : '' %>">
                    <i class="fas fa-envelope w-6"></i> Messages
                </a>
            </nav>
        </div>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-hidden w-full">
            <header class="bg-white shadow-sm border-b border-gray-200 z-10">
                <div class="px-4 md:px-6 py-4 flex items-center justify-between">
                    <div class="flex items-center">
                        <button onclick="toggleMobileMenu()" class="md:hidden mr-3 text-gray-600 hover:text-gray-900 focus:outline-none">
                            <i class="fas fa-bars text-xl"></i>
                        </button>
                        <h2 class="text-xl md:text-2xl font-semibold text-gray-800"><%= title %></h2>
                    </div>
                    <div class="flex items-center space-x-4">
                        <div class="relative">
                            <span class="absolute top-0 right-0 h-2 w-2 bg-red-500 rounded-full"></span>
                            <i class="fas fa-bell text-gray-600 text-lg cursor-pointer"></i>
                        </div>
                        <div class="relative group">
                            <div class="h-8 w-8 rounded-full bg-blue-500 flex items-center justify-center text-white font-bold cursor-pointer">
                                <% if (user && user.email) { %>
                                    <%= user.email.charAt(0).toUpperCase() %>
                                <% } else { %>
                                    A
                                <% } %>
                            </div>
                            <!-- Dropdown Menu -->
                            <div class="hidden group-hover:block absolute right-0 mt-2 w-48 bg-white rounded-lg shadow-lg py-2 z-50">
                                <% if (user && user.email) { %>
                                    <div class="px-4 py-2 text-sm text-gray-600 border-b">
                                        <%= user.email %>
                                    </div>
                                <% } %>
                                <a href="/auth/logout" class="block px-4 py-2 text-sm text-red-600 hover:bg-red-50 transition-colors">
                                    <i class="fas fa-sign-out-alt mr-2"></i> Logout
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Content -->
            <main class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-100 p-4 md:p-6">
                <%- body %>
            </main>
        </div>
    </div>

    <script src="/js/admin/common.js"></script>
    <script>
        function toggleMobileMenu() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('mobileMenuOverlay');
            
            sidebar.classList.toggle('open');
            sidebar.classList.toggle('-translate-x-full'); // Tailwind class toggle if used
            
            if (sidebar.classList.contains('open')) {
                overlay.classList.remove('hidden');
                sidebar.classList.remove('-translate-x-full'); // Ensure it shows
            } else {
                overlay.classList.add('hidden');
                sidebar.classList.add('-translate-x-full'); // Hide it
            }
        }
        
        // Initial state fix for mobile
        document.addEventListener('DOMContentLoaded', () => {
            const sidebar = document.getElementById('sidebar');
            if (window.innerWidth < 768) {
                sidebar.classList.add('-translate-x-full');
            } else {
                sidebar.classList.remove('-translate-x-full');
            }
        });
    </script>
</body>
</html>
