<%- include('layout', { title: 'Projects', currentPage: 'projects', body: `
<div class="bg-white rounded-lg shadow">
    <div class="p-4 md:p-6 border-b border-gray-200 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
        <h3 class="text-lg font-semibold text-gray-800">Projects Management</h3>
        <a href="/admin/add-project" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors font-medium">
            <i class="fas fa-plus mr-2"></i>Add Project
        </a>
    </div>
    
    <div class="p-4 md:p-6">

        <!-- Search -->
        <div class="mb-6">
            <input type="text" id="searchInput" placeholder="Search projects..." 
                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500">
        </div>

        <!-- Desktop Table -->
        <div class="hidden md:block overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs text-gray-500 uppercase">Project</th>
                        <th class="px-6 py-3 text-left text-xs text-gray-500 uppercase">Social</th>
                        <th class="px-6 py-3 text-left text-xs text-gray-500 uppercase">Contact</th>
                        <th class="px-6 py-3 text-left text-xs text-gray-500 uppercase">Date</th>
                        <th class="px-6 py-3 text-left text-xs text-gray-500 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody id="projectsTableBody"></tbody>
            </table>
        </div>

        <!-- Mobile -->
        <div id="mobileView" class="md:hidden space-y-4"></div>

        <!-- Empty -->
        <div id="emptyMessage" class="hidden text-center py-8 text-gray-500">
            <i class="fas fa-inbox text-4xl mb-2"></i>
            <p id="emptyText">No projects found</p>
        </div>

    </div>
</div>

<script>
let allProjects = [];

document.addEventListener('DOMContentLoaded', () => {
    loadProjects();
    document.getElementById('searchInput').addEventListener('input', filterProjects);
});

// ✅ Safe URL
function safeUrl(url) {
    if (!url) return '#';
    return url.startsWith('http') ? url : '#';
}

// ✅ Load projects
async function loadProjects() {
    try {
        const res = await fetch('/api/projects');
        const result = await res.json();

        console.log('API:', result);

        if (result && result.data) {
            allProjects = result.data;
            renderProjects(allProjects);
        } else {
            showEmpty('Failed to load projects');
        }
    } catch (err) {
        console.error(err);
        showEmpty('Error loading projects');
    }
}

// ✅ Render
function renderProjects(projects) {
    const table = document.getElementById('projectsTableBody');
    const mobile = document.getElementById('mobileView');

    if (!projects || projects.length === 0) {
        table.innerHTML = '';
        mobile.innerHTML = '';
        showEmpty('No projects found');
        return;
    }

    hideEmpty();

    // Desktop
    table.innerHTML = projects.map(p => \`
        <tr>
            <td class="px-6 py-4">
                <div class="flex items-center">
                    \${p.coverPhoto 
                        ? \`<img class="h-10 w-10 rounded-full object-cover" src="\${p.coverPhoto}">\`
                        : \`<div class="h-10 w-10 bg-blue-100 flex items-center justify-center rounded-full text-blue-500"><i class="fas fa-project-diagram"></i></div>\`}
                    <div class="ml-4">
                        <div class="text-sm font-medium">\${p.name || 'Untitled'}</div>
                        <div class="text-xs text-gray-500">ID: \${p.id || '-'}</div>
                    </div>
                </div>
            </td>

            <td class="px-6 py-4">
                <div class="flex gap-2">
                    \${p.instagramLink ? \`<a href="\${safeUrl(p.instagramLink)}" target="_blank" class="text-pink-600"><i class="fab fa-instagram"></i></a>\` : ''}
                    \${p.facebookLink ? \`<a href="\${safeUrl(p.facebookLink)}" target="_blank" class="text-blue-600"><i class="fab fa-facebook"></i></a>\` : ''}
                    \${p.tiktokLink ? \`<a href="\${safeUrl(p.tiktokLink)}" target="_blank" class="text-black"><i class="fab fa-tiktok"></i></a>\` : ''}
                    \${(!p.instagramLink && !p.facebookLink && !p.tiktokLink) ? '<span>-</span>' : ''}
                </div>
            </td>

            <td class="px-6 py-4 text-sm text-gray-500">
                \${p.contact || '-'}
            </td>

            <td class="px-6 py-4 text-sm text-gray-500">
                \${p.created_at ? new Date(p.created_at).toLocaleDateString() : '-'}
            </td>

            <td class="px-6 py-4 text-sm">
                <button onclick="editProject(\${p.id})" class="text-indigo-600 mr-2">Edit</button>
                <button onclick="deleteProject(\${p.id})" class="text-red-600">Delete</button>
            </td>
        </tr>
    \`).join('');

    // Mobile
    mobile.innerHTML = projects.map(p => \`
        <div class="bg-white shadow rounded-lg p-4">
            <div class="flex justify-between mb-3">
                <div class="flex items-center">
                    \${p.coverPhoto 
                        ? \`<img class="h-10 w-10 rounded-full mr-3" src="\${p.coverPhoto}">\`
                        : \`<div class="h-10 w-10 bg-blue-100 flex items-center justify-center rounded-full mr-3"><i class="fas fa-project-diagram"></i></div>\`}
                    <div>
                        <h3 class="font-medium">\${p.name || 'Untitled'}</h3>
                        <p class="text-xs text-gray-500">ID: \${p.id || '-'}</p>
                    </div>
                </div>
                <span class="text-xs text-gray-500">
                    \${p.created_at ? new Date(p.created_at).toLocaleDateString() : '-'}
                </span>
            </div>

            <p class="text-sm mb-2"><strong>Contact:</strong> \${p.contact || '-'}</p>

            <div class="flex gap-3 mb-3">
                \${p.instagramLink ? \`<a href="\${safeUrl(p.instagramLink)}"><i class="fab fa-instagram text-pink-600"></i></a>\` : ''}
                \${p.facebookLink ? \`<a href="\${safeUrl(p.facebookLink)}"><i class="fab fa-facebook text-blue-600"></i></a>\` : ''}
                \${p.tiktokLink ? \`<a href="\${safeUrl(p.tiktokLink)}"><i class="fab fa-tiktok"></i></a>\` : ''}
            </div>

            <div class="flex justify-end gap-3 border-t pt-2">
                <button onclick="editProject(\${p.id})" class="text-indigo-600 text-sm">Edit</button>
                <button onclick="deleteProject(\${p.id})" class="text-red-600 text-sm">Delete</button>
            </div>
        </div>
    \`).join('');
}

// ✅ Search
function filterProjects() {
    const term = document.getElementById('searchInput').value.toLowerCase();

    const filtered = allProjects.filter(p =>
        (p.name || '').toLowerCase().includes(term) ||
        (p.contact || '').toLowerCase().includes(term)
    );

    renderProjects(filtered);
}

// ✅ Actions
function editProject(id) {
    window.location.href = \`/admin/edit-project/\${id}\`;
}

function deleteProject(id) {
    if (!confirm('Delete this project?')) return;

    fetch(\`/api/projects/\${id}\`, { method: 'DELETE' })
        .then(() => loadProjects())
        .catch(() => alert('Delete failed'));
}

// ✅ Empty state
function showEmpty(msg) {
    document.getElementById('emptyMessage').classList.remove('hidden');
    document.getElementById('emptyText').innerText = msg;
}

function hideEmpty() {
    document.getElementById('emptyMessage').classList.add('hidden');
}
</script>
` }) %>