<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title || 'Admin Panel' %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        @media (max-width: 768px) {
            .sidebar-mobile {
                transform: translateX(-100%);
                transition: transform 0.3s ease-in-out;
            }
            .sidebar-mobile.open {
                transform: translateX(0);
            }
        }
    </style>
</head>
<body class="bg-gray-50">
    <div class="min-h-screen flex overflow-hidden">
        <!-- Mobile Menu Overlay -->
        <div id="mobileOverlay" class="fixed inset-0 bg-black bg-opacity-50 z-20 hidden md:hidden" onclick="toggleMenu()"></div>
        
        <!-- Sidebar -->
        <div id="sidebar" class="sidebar-mobile fixed md:static inset-y-0 left-0 z-30 w-64 bg-white shadow-lg overflow-y-auto md:translate-x-0">
            <div class="p-4 md:p-6 border-b flex items-center justify-between">
                <h1 class="text-xl font-bold text-gray-800">Admin Panel</h1>
                <button onclick="toggleMenu()" class="md:hidden text-gray-600 hover:text-gray-900">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            <nav class="mt-6">
                <a href="/admin" class="flex items-center px-6 py-3 text-gray-700 hover:bg-gray-100 <%= page === 'dashboard' ? 'bg-blue-50 text-blue-600 border-r-2 border-blue-600' : '' %>">
                    <i class="fas fa-home mr-3"></i>
                    Dashboard
                </a>
                <a href="/admin/projects" class="flex items-center px-6 py-3 text-gray-700 hover:bg-gray-100 <%= page === 'projects' ? 'bg-blue-50 text-blue-600 border-r-2 border-blue-600' : '' %>">
                    <i class="fas fa-folder mr-3"></i>
                    Projects
                </a>
                <a href="/admin/clients" class="flex items-center px-6 py-3 text-gray-700 hover:bg-gray-100 <%= page === 'clients' ? 'bg-blue-50 text-blue-600 border-r-2 border-blue-600' : '' %>">
                    <i class="fas fa-users mr-3"></i>
                    Clients
                </a>
                <a href="/admin/messages" class="flex items-center px-6 py-3 text-gray-700 hover:bg-gray-100 <%= page === 'messages' ? 'bg-blue-50 text-blue-600 border-r-2 border-blue-600' : '' %>">
                    <i class="fas fa-envelope mr-3"></i>
                    Messages
                </a>
            </nav>
        </div>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-hidden w-full">
            <header class="bg-white shadow-sm border-b px-4 md:px-6 py-4">
                <div class="flex items-center">
                    <button onclick="toggleMenu()" class="md:hidden mr-3 text-gray-600 hover:text-gray-900">
                        <i class="fas fa-bars text-xl"></i>
                    </button>
                    <h2 class="text-xl md:text-2xl font-semibold text-gray-800"><%= title || 'Dashboard' %></h2>
                </div>
            </header>
            <main class="flex-1 overflow-x-hidden overflow-y-auto p-4 md:p-6">
                <%- body %>
            </main>
        </div>
    </div>
    
    <script>
        function toggleMenu() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('mobileOverlay');
            sidebar.classList.toggle('open');
            overlay.classList.toggle('hidden');
        }
    </script>
</body>
</html>