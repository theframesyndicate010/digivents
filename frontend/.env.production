# Production API Configuration
# Update this to match your live Strapi backend URL

# Option 1: If backend is on same domain (e.g., https://digivents.com.np)
REACT_APP_API_URL=https://digivents.com.np

# Option 2: If backend is on separate subdomain (uncomment and update)
# REACT_APP_API_URL=https://api.digivents.com.np

# Option 3: If using relative path and backend is behind a proxy (uncomment)
# REACT_APP_API_URL=/api
